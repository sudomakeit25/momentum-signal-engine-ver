{
  "expo": {
    "name": "MSE",
    "slug": "mse-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "mse",
    "extra": {
      "apiBase": "https://momentum-signal-engine.onrender.com"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#22d3ee"
        }
      ]
    ],
    "notification": {
      "icon": "./assets/icon.png",
      "color": "#22d3ee"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090b"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sudomakeit25.mse"
    },
    "android": {
      "package": "com.sudomakeit25.mse",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#09090b"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
