# Alpaca API credentials
# Get your keys at https://app.alpaca.markets/
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# Use "paper" for paper trading, "live" for real trading
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# CORS - comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Cache settings
CACHE_DIR=.cache
CACHE_TTL_MINUTES=15

# Polygon.io (Options Flow Scanner - free tier)
POLYGON_API_KEY=your_polygon_key_here

# Financial Modeling Prep (Earnings Whisper - free tier)
FMP_API_KEY=your_fmp_key_here

# Upstash Redis (persistent config storage)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
